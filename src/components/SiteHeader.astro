---
const { lang = 'ro' } = Astro.props;
const isRo = lang === 'ro';
---

<header class="site-header">
	<div class="container header-wrap">
		<a href={isRo ? '/' : '/en/'} class="brand" aria-label="Smarteye home">
			<img src="/logo-smarteye-header.png" alt="Smarteye" />
		</a>
		<nav>
			<a href={isRo ? '/' : '/en/'}>{isRo ? 'Acasa' : 'Home'}</a>
			<a href={isRo ? '/despre-noi' : '/en/about'}>{isRo ? 'Despre noi' : 'About'}</a>
			<a href={isRo ? '/licenta' : '/en/license'}>{isRo ? 'Licenta' : 'License'}</a>
			<a href={isRo ? '/contact' : '/en/contact'}>{isRo ? 'Contact' : 'Contact'}</a>
			<a href={isRo ? '/en/' : '/'} class="lang">{isRo ? 'EN' : 'RO'}</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		background: rgba(11, 16, 32, 0.82);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid rgba(169, 182, 211, 0.18);
		position: sticky;
		top: 0;
		z-index: 10;
	}

	.header-wrap {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.9rem 0;
	}

	.brand {
		text-decoration: none;
		display: inline-flex;
		align-items: center;
	}

	.brand img {
		height: 30px;
		width: auto;
		display: block;
	}

	nav {
		display: flex;
		gap: 1rem;
		align-items: center;
	}

	nav a {
		color: #cdd8f6;
		text-decoration: none;
		font-weight: 600;
	}

	.lang {
		padding: 0.4rem 0.7rem;
		border: 1px solid rgba(169, 182, 211, 0.25);
		border-radius: 0.7rem;
		background: rgba(23, 34, 58, 0.6);
	}

	@media (max-width: 640px) {
		.brand img {
			height: 25px;
		}

		.header-wrap {
			padding: 0.78rem 0;
		}

		nav {
			gap: 0.7rem;
		}

		nav a {
			font-size: 0.92rem;
		}
	}
</style>
