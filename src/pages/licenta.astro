---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import LicenseCertificateCard from '../components/LicenseCertificateCard.astro';
---

<Layout
	lang="ro"
	title="Licenta sisteme de securitate - Smarteye"
	description="Detalii despre licenta Smarteye pentru sisteme de securitate."
>
	<SiteHeader lang="ro" />
	<main class="section">
		<div class="container">
			<h1>Licenta sisteme de securitate</h1>
			<div class="grid license-grid">
				<LicenseCertificateCard lang="ro" />
				<article class="card license-legal">
					<h2>Cadrul legal</h2>
					<p>
						Conform <strong>Legii nr. 333/2003</strong> privind paza obiectivelor, bunurilor,
						valorilor și protecția persoanelor, activitățile de proiectare, instalare, modificare
						sau întreținere a sistemelor tehnice de protecție și de alarmare împotriva efracției
						pot fi desfășurate numai de persoane fizice sau juridice care dețin licență eliberată
						de autoritatea competentă (Inspectoratul General al Poliției Române), în condițiile
						prevăzute la <strong>art. 34</strong> din aceeași lege și în normele metodologice de
						aplicare (Hotărârea Guvernului nr. 301/2012).
					</p>
					<p class="license-legal-source">
						<a
							href="https://legislatie.just.ro/Public/DetaliiDocument/41868"
							target="_blank"
							rel="noopener noreferrer"
							>Legea 333/2003 – text oficial (legislatie.just.ro)</a
						>
					</p>
				</article>
			</div>
		</div>
	</main>
	<SiteFooter lang="ro" />
</Layout>

<style>
	.license-grid {
		margin-top: 1rem;
		grid-template-columns: 1fr;
		align-items: start;
	}

	/* PC: licență 60% · cadrul legal 40% */
	@media (min-width: 900px) {
		.license-grid {
			grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
		}
	}
</style>
