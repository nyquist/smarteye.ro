---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Layout from '../layouts/Layout.astro';
import { packagesRo } from '../data/packages.js';
import { sitePath } from '../utils/sitePath';

const packageLabelsRo = {
	'sistem-alarmare-cu-fir': 'Eficient',
	'sistem-alarmare-wireless': 'Recomandat',
	'sistem-supraveghere-video-interior': 'Popular',
	'sistem-supraveghere-video-exterior': 'Premium'
};

const packageTagVariantRo = {
	'sistem-alarmare-cu-fir': 'tag-efficient',
	'sistem-alarmare-wireless': 'tag-recommended',
	'sistem-supraveghere-video-interior': 'tag-popular',
	'sistem-supraveghere-video-exterior': 'tag-premium'
};
---

<Layout
	lang="ro"
	title="Smarteye - Sisteme de alarma si supraveghere"
	description="Sisteme de securitate pentru casa si business: alarma cu fir, wireless si supraveghere video."
>
	<SiteHeader lang="ro" />
	<main>
		<section class="section hero">
			<div class="container">
				<h1>Securitate inteligenta, instalata profesionist.</h1>
				<p>
					Sisteme de alarmare si supraveghere video pentru locuinte si companii care vor
					control, fiabilitate si raspuns rapid.
				</p>
				<div class="actions">
					<a class="button" href={sitePath('contact')}>Cere oferta</a>
					<a class="button secondary" href="#pachete">Vezi pachetele</a>
				</div>
				<div class="chips">
					<span class="chip">Instalare rapida</span>
					<span class="chip">Echipamente fiabile</span>
					<span class="chip">Suport dedicat</span>
				</div>
			</div>
		</section>
		<section class="section" id="pachete">
			<div class="container">
				<h2 class="section-title">Pachete recomandate</h2>
				<div class="grid">
					{
						packagesRo.map((pkg) => (
							<article class="card package-card">
								<span class={`tag ${packageTagVariantRo[pkg.slug]}`}>{packageLabelsRo[pkg.slug]}</span>
								<h3>{pkg.name}</h3>
								<p class="price"><strong>{pkg.price}</strong></p>
								<ul>
									{pkg.items.map((item) => (
										<li>{item}</li>
									))}
								</ul>
								<a class="button package-btn" href={sitePath('contact')}>Cere oferta</a>
							</article>
						))
					}
				</div>
			</div>
		</section>
		<section class="section">
			<div class="container">
				<h2 class="section-title">De ce Smarteye</h2>
				<div class="grid">
					<article class="card">
						<h3>Expertiza tehnica</h3>
						<p>Configuram sistemele dupa nevoile reale ale locatiei, nu dupa sabloane rigide.</p>
					</article>
					<article class="card">
						<h3>Monitorizare eficienta</h3>
						<p>Ai acces rapid la informatii si alerte pentru reactii mai rapide la incidente.</p>
					</article>
					<article class="card">
						<h3>Instalare curata</h3>
						<p>Implementare organizata, cu testare finala si predare clara a sistemului.</p>
					</article>
					<article class="card">
						<h3>Suport post-instalare</h3>
						<p>Ramanem alaturi de tine pentru optimizari, mentenanta si extinderi.</p>
					</article>
				</div>
			</div>
		</section>
		<section class="section">
			<div class="container">
				<h2 class="section-title">Cum lucram</h2>
				<div class="grid steps">
					<article class="card">
						<p class="step-no">01</p>
						<h3>Evaluare si recomandare</h3>
						<p>Discutam contextul locatiei si alegem pachetul potrivit.</p>
					</article>
					<article class="card">
						<p class="step-no">02</p>
						<h3>Instalare si configurare</h3>
						<p>Implementam sistemul si calibram functiile esentiale.</p>
					</article>
					<article class="card">
						<p class="step-no">03</p>
						<h3>Predare si suport</h3>
						<p>Te instruim si ramanem disponibili pentru asistenta ulterioara.</p>
					</article>
				</div>
			</div>
		</section>
		<section class="section">
			<div class="container card cta-final">
				<h2>Gata sa iti securizezi proprietatea?</h2>
				<p>
					Trimite-ne cererea ta si revenim rapid cu o recomandare clara pentru casa sau business.
				</p>
				<div class="actions">
					<a class="button" href={sitePath('contact')}>Cere oferta</a>
					<a class="button secondary" href="tel:+40xxxxxxxxx">Suna acum</a>
				</div>
			</div>
		</section>
	</main>
	<SiteFooter lang="ro" />
	<a class="mobile-cta" href={sitePath('contact')}>Cere oferta</a>
</Layout>

<style>
	.hero h1 {
		font-size: clamp(2rem, 5vw, 3.35rem);
		max-width: 16ch;
	}

	.hero p {
		max-width: 62ch;
	}

	.actions {
		display: flex;
		gap: 0.72rem;
		flex-wrap: wrap;
		margin: 1.2rem 0;
	}

	.price {
		color: #d6e7ff;
	}

	.package-card {
		position: relative;
	}

	.tag {
		position: static;
		display: inline-flex;
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 0.3rem 0.58rem;
		margin-bottom: 0.55rem;
		border-radius: 999px;
		background: linear-gradient(120deg, #ef4444, #dc2626);
		color: #fff;
		border: 1px solid rgba(255, 255, 255, 0.35);
		box-shadow: 0 8px 18px rgba(220, 38, 38, 0.45);
	}

	.tag-efficient {
		background: linear-gradient(120deg, #475569, #334155);
		box-shadow: 0 8px 18px rgba(51, 65, 85, 0.5);
	}

	.tag-recommended {
		background: linear-gradient(120deg, #ef4444, #dc2626);
		box-shadow: 0 8px 18px rgba(220, 38, 38, 0.45);
	}

	.tag-popular {
		background: linear-gradient(120deg, #f97316, #ea580c);
		box-shadow: 0 8px 18px rgba(234, 88, 12, 0.45);
	}

	.tag-premium {
		background: linear-gradient(120deg, #7c3aed, #6d28d9);
		box-shadow: 0 8px 18px rgba(109, 40, 217, 0.45);
	}

	.package-btn {
		margin-top: 0.6rem;
	}

	ul {
		margin: 0 0 1rem;
		padding-left: 1rem;
		color: #b9c8e8;
	}

	li {
		margin-bottom: 0.4rem;
	}

	.steps {
		grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
	}

	.step-no {
		font-size: 0.78rem;
		font-weight: 700;
		color: #ffb3b3;
		letter-spacing: 0.08em;
	}

	.cta-final {
		padding: 1.7rem;
	}

	.mobile-cta {
		display: none;
	}

	@media (max-width: 680px) {
		.mobile-cta {
			display: block;
			position: fixed;
			left: 1rem;
			right: 1rem;
			bottom: 1rem;
			text-align: center;
			text-decoration: none;
			padding: 0.85rem 1rem;
			border-radius: 0.8rem;
			background: linear-gradient(120deg, #ef4444, #f97316);
			color: #fff;
			font-weight: 700;
			box-shadow: 0 10px 20px rgba(15, 23, 42, 0.5);
			z-index: 20;
		}
	}
</style>
