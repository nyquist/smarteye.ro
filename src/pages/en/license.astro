---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import LicenseCertificateCard from '../../components/LicenseCertificateCard.astro';
---

<Layout
	lang="en"
	title="Security License - Smarteye"
	description="Smarteye security systems license details."
>
	<SiteHeader lang="en" />
	<main class="section">
		<div class="container">
			<h1>Security License</h1>
			<div class="grid license-grid">
				<LicenseCertificateCard lang="en" />
				<article class="card license-legal">
					<h2>Legal framework</h2>
					<p>
						Under Romanian <strong>Law no. 333/2003</strong> on guarding objectives, property,
						values and the protection of persons, design, installation, modification or
						maintenance of technical protection and anti-burglar alarm systems may only be carried
						out by natural or legal persons holding a licence issued by the competent authority
						(Romanian General Police Inspectorate), as set out in <strong>Article 34</strong> of
						the same law and in the implementing rules (Government Decision no. 301/2012).
					</p>
					<p class="license-legal-source">
						<a
							href="https://legislatie.just.ro/Public/DetaliiDocument/41868"
							target="_blank"
							rel="noopener noreferrer"
							>Law 333/2003 – official text (legislatie.just.ro)</a
						>
					</p>
				</article>
			</div>
		</div>
	</main>
	<SiteFooter lang="en" />
</Layout>

<style>
	.license-grid {
		margin-top: 1rem;
		grid-template-columns: 1fr;
		align-items: start;
	}

	/* Desktop: licence 60% · legal 40% */
	@media (min-width: 900px) {
		.license-grid {
			grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
		}
	}
</style>
