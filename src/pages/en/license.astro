---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
---

<Layout
	lang="en"
	title="Security License - Smarteye"
	description="Smarteye security license details and public contact information."
>
	<SiteHeader lang="en" />
	<main class="section">
		<div class="container">
			<h1>Security License</h1>
			<div class="grid license-grid">
				<article class="card">
					<h2>License</h2>
					<p><strong>No:</strong> 1734/T/14.07.2009</p>
					<figure class="license-figure">
						<img
							src="/licenta-2015.png"
							alt="Smarteye security systems license"
							width="796"
							height="553"
							loading="lazy"
						/>
					</figure>
				</article>
				<article class="card">
					<h2>Contact details</h2>
					<p><strong>Phone:</strong> 0725 252 762, 021 2310 697</p>
					<p><strong>Email:</strong> office@smarteye.ro, vanzari@smarteye.ro, service@smarteye.ro</p>
					<p>
						<strong>Address:</strong> Strada Pictor Stefan Luchian no. 20, room 3, Sector 2,
						Bucharest, CP 023958
					</p>
				</article>
			</div>
		</div>
	</main>
	<SiteFooter lang="en" />
</Layout>

<style>
	.license-grid {
		margin-top: 1rem;
	}

	.license-figure {
		margin: 0.75rem 0 0;
		border-radius: 0.75rem;
		overflow: hidden;
		border: 1px solid var(--border);
		background: #0a0f1f;
	}

	.license-figure img {
		display: block;
		width: 100%;
		height: auto;
	}
</style>
