---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
	lang="en"
	title="Contact - Smarteye"
	description="Smarteye contact details and quote request information."
>
	<SiteHeader lang="en" />
	<main class="section">
		<div class="container">
			<h1>Contact</h1>
			<p>Send us a message for quote requests, installation, maintenance, or support.</p>
			<div class="grid contact-grid">
				<article class="card">
					<h2>Office address</h2>
					<p>Bucharest, Pictor Stefan Luchian Street no. 20, room 3, district 2.</p>
					<div class="map-wrap">
						<iframe
							title="Smarteye location map"
							src="https://www.google.com/maps?q=Strada%20Pictor%20Stefan%20Luchian%2020%2C%20Bucuresti&output=embed"
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"
						></iframe>
					</div>
				</article>
				<article class="card form-card">
					<h2>Send a message</h2>
					<p>
						Briefly describe what you need (alarm, video, maintenance) and we will reply with next
						steps. You can also use phone or email from the footer.
					</p>
					<ContactForm lang="en" />
				</article>
			</div>
		</div>
	</main>
	<SiteFooter lang="en" />
</Layout>

<style>
	.contact-grid {
		margin-top: 1rem;
	}

	.map-wrap {
		margin-top: 0.6rem;
		border: 1px solid var(--border);
		border-radius: 0.9rem;
		overflow: hidden;
		background: #0a0f1f;
	}

	.map-wrap iframe {
		display: block;
		width: 100%;
		height: 280px;
		border: 0;
	}
</style>
