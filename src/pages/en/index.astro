---
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import HeroTechGraphic from '../../components/HeroTechGraphic.astro';
import Layout from '../../layouts/Layout.astro';
import { packagesRo } from '../../data/packages.js';
import { sitePath } from '../../utils/sitePath';

const packagesEn = packagesRo.map((pkg) => ({
	...pkg,
	name:
		pkg.slug === 'sistem-alarmare-cu-fir'
			? 'Wired Alarm System'
			: pkg.slug === 'sistem-alarmare-wireless'
				? 'Wireless Alarm System'
				: pkg.slug === 'sistem-supraveghere-video-interior'
					? 'Indoor Video Surveillance System'
					: 'Outdoor Video Surveillance System'
}));

const packageLabelsEn = {
	'sistem-alarmare-cu-fir': 'Value',
	'sistem-alarmare-wireless': 'Recommended',
	'sistem-supraveghere-video-interior': 'Popular',
	'sistem-supraveghere-video-exterior': 'Premium'
};

const packageTagVariantEn = {
	'sistem-alarmare-cu-fir': 'tag-efficient',
	'sistem-alarmare-wireless': 'tag-recommended',
	'sistem-supraveghere-video-interior': 'tag-popular',
	'sistem-supraveghere-video-exterior': 'tag-premium'
};
---

<Layout
	lang="en"
	title="Smarteye - Alarm and video security systems"
	description="Security systems for homes and businesses: wired alarm, wireless alarm and video surveillance."
>
	<SiteHeader lang="en" />
	<main class="page-home-en">
		<section class="section hero">
			<div class="container hero-shell">
				<div class="hero-main">
					<div class="hero-copy">
						<h1>Smart security, installed professionally.</h1>
						<p>
							Alarm and video surveillance systems for homes and businesses that need control,
							reliability, and fast response.
						</p>
						<div class="actions">
							<a class="button" href={sitePath('en/contact')}>Request offer</a>
							<a class="button secondary" href="#packages">View packages</a>
						</div>
						<div class="chips">
							<span class="chip">Fast installation</span>
							<span class="chip">Reliable equipment</span>
							<span class="chip">Dedicated support</span>
						</div>
					</div>
					<div class="hero-art">
						<HeroTechGraphic lang="en" />
					</div>
				</div>
			</div>
		</section>
		<section class="section" id="packages">
			<div class="container">
				<h2 class="section-title">Recommended packages</h2>
				<div class="grid">
					{
						packagesEn.map((pkg) => (
							<article class="card package-card">
								<span class={`tag ${packageTagVariantEn[pkg.slug]}`}>{packageLabelsEn[pkg.slug]}</span>
								<h3>{pkg.name}</h3>
								<p class="price"><strong>{pkg.price}</strong></p>
								<ul>
									{pkg.items.map((item) => (
										<li>{item}</li>
									))}
								</ul>
								<a class="button package-btn" href={sitePath('en/contact')}>Request offer</a>
							</article>
						))
					}
				</div>
			</div>
		</section>
		<section class="section">
			<div class="container">
				<h2 class="section-title">Why Smarteye</h2>
				<div class="grid">
					<article class="card">
						<h3>Technical expertise</h3>
						<p>We tailor each setup to your location and use-case, not generic templates.</p>
					</article>
					<article class="card">
						<h3>Efficient monitoring</h3>
						<p>Quick access to alerts and system status for better incident response.</p>
					</article>
					<article class="card">
						<h3>Clean installation</h3>
						<p>Organized implementation with final testing and clear handover.</p>
					</article>
					<article class="card">
						<h3>Post-install support</h3>
						<p>We stay available for maintenance, optimization, and future upgrades.</p>
					</article>
				</div>
			</div>
		</section>
		<section class="section">
			<div class="container">
				<h2 class="section-title">How we work</h2>
				<div class="grid steps">
					<article class="card">
						<p class="step-no">01</p>
						<h3>Assessment and recommendation</h3>
						<p>We review your property and define the right solution.</p>
					</article>
					<article class="card">
						<p class="step-no">02</p>
						<h3>Installation and setup</h3>
						<p>We install and configure all essential system functions.</p>
					</article>
					<article class="card">
						<p class="step-no">03</p>
						<h3>Handover and support</h3>
						<p>You get guided onboarding and ongoing assistance after delivery.</p>
					</article>
				</div>
			</div>
		</section>
		<section class="section">
			<div class="container card cta-final">
				<h2>Ready to secure your property?</h2>
				<p>Send us your request and we will return with a clear recommendation.</p>
				<div class="actions">
					<a class="button" href={sitePath('en/contact')}>Request offer</a>
					<a class="button secondary" href="tel:+40xxxxxxxxx">Call now</a>
				</div>
			</div>
		</section>
	</main>
	<SiteFooter lang="en" />
	<a class="mobile-cta" href={sitePath('en/contact')}>Request offer</a>
</Layout>

<style>
	.hero-shell {
		position: relative;
	}

	.hero-main {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(260px, 44%);
		gap: clamp(1.5rem, 4vw, 3rem);
		align-items: center;
	}

	/* English headlines are longer than RO — avoid 16ch squeeze */
	.page-home-en .hero-copy {
		min-width: 0;
	}

	.page-home-en .hero-copy h1 {
		font-size: clamp(2rem, 5vw, 3.2rem);
		max-width: 20rem;
		line-height: 1.12;
		text-wrap: balance;
	}

	.page-home-en .hero-copy p {
		max-width: 38rem;
	}

	/* Long package titles in English */
	.page-home-en .package-card h3 {
		font-size: 1.05rem;
		line-height: 1.3;
		overflow-wrap: anywhere;
		word-break: break-word;
	}

	.page-home-en .grid {
		align-items: stretch;
	}

	.page-home-en .grid > .card {
		min-width: 0;
	}

	.hero-art {
		justify-self: end;
		width: 100%;
	}

	@media (max-width: 960px) {
		.hero-main {
			grid-template-columns: 1fr;
		}

		.hero-art {
			justify-self: stretch;
			order: -1;
			max-width: 420px;
			margin-inline: auto;
		}
	}

	.actions {
		display: flex;
		gap: 0.72rem;
		flex-wrap: wrap;
		margin: 1.2rem 0;
	}

	.price {
		color: #d6e7ff;
	}

	.package-card {
		position: relative;
	}

	.tag {
		position: static;
		display: inline-flex;
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 0.3rem 0.58rem;
		margin-bottom: 0.55rem;
		border-radius: 999px;
		background: linear-gradient(120deg, #ef4444, #dc2626);
		color: #fff;
		border: 1px solid rgba(255, 255, 255, 0.35);
		box-shadow: 0 8px 18px rgba(220, 38, 38, 0.45);
	}

	.tag-efficient {
		background: linear-gradient(120deg, #475569, #334155);
		box-shadow: 0 8px 18px rgba(51, 65, 85, 0.5);
	}

	.tag-recommended {
		background: linear-gradient(120deg, #ef4444, #dc2626);
		box-shadow: 0 8px 18px rgba(220, 38, 38, 0.45);
	}

	.tag-popular {
		background: linear-gradient(120deg, #f97316, #ea580c);
		box-shadow: 0 8px 18px rgba(234, 88, 12, 0.45);
	}

	.tag-premium {
		background: linear-gradient(120deg, #7c3aed, #6d28d9);
		box-shadow: 0 8px 18px rgba(109, 40, 217, 0.45);
	}

	.package-btn {
		margin-top: 0.6rem;
	}

	ul {
		margin: 0 0 1rem;
		padding-left: 1rem;
		color: #b9c8e8;
	}

	li {
		margin-bottom: 0.4rem;
	}

	.steps {
		grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
	}

	.step-no {
		font-size: 0.78rem;
		font-weight: 700;
		color: #ffb3b3;
		letter-spacing: 0.08em;
	}

	.cta-final {
		padding: 1.7rem;
	}

	.mobile-cta {
		display: none;
	}

	@media (max-width: 680px) {
		.mobile-cta {
			display: block;
			position: fixed;
			left: 1rem;
			right: 1rem;
			bottom: 1rem;
			text-align: center;
			text-decoration: none;
			padding: 0.85rem 1rem;
			border-radius: 0.8rem;
			background: linear-gradient(120deg, #ef4444, #f97316);
			color: #fff;
			font-weight: 700;
			box-shadow: 0 10px 20px rgba(15, 23, 42, 0.5);
			z-index: 20;
		}
	}
</style>
